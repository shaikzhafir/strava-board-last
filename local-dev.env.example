# Copy to `.dev.vars` at the repo root for `npm run dev:local` only.
# (Filename is NOT `.dev.vars.example` — Cloudflare’s Deploy button prompts for
# every variable listed in `.dev.vars.example`, which would wrongly ask for
# Strava keys at deploy time. Production uses the in-app wizard → KV.)
#
# Create the Strava app at https://www.strava.com/settings/api with
# Authorization Callback Domain set to "localhost".

# Uncomment so Client ID/Secret from this file override wizard KV (local only).
# Changing ID/secret clears Strava owner/tokens/cache so you can re-OAuth; restart dev.
# STRAVA_PREFER_DEV_VARS=true

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
